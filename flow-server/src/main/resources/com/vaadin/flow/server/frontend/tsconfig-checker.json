// This TypeScript configuration file is generated by vaadin-maven-plugin into
// the build directory and is used only by vite-plugin-checker to run type
// checking. It inherits the project tsconfig.json but excludes the
// generated/jar-resources folder, so add-on sources (which are outside the
// project developer's control) are compiled by the bundler but not type
// checked. This file is regenerated on every build; do not edit or commit it.
{
  "extends": "../tsconfig.json",
  "exclude": [
    "../%FRONTEND%/generated/jar-resources/**"
  ]
}
